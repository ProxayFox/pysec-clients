{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/*.pyo": true,
        "**/*.pyd": true,
        "**/*.egg-info": true,
        ".pytest_cache": true,
        ".venv": true,
        ".direnv": true,
        ".githooks": true,
        ".envrc": true,
        ".ruff_cache": true,
    },
    "editor.formatOnSave": true,
    "chat.agent.maxRequests": 250,
    "chat.tools.terminal.autoApprove": {
        "just": true
    },
    "python.testing.pytestArgs": [
        "test"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true
}